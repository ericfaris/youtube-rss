# Public URL of your Railway app (no trailing slash)
BASE_URL=https://yourapp.railway.app

# HTTP Basic Auth (leave blank to disable)
AUTH_USER=admin
AUTH_PASS=changeme

# How many episodes to keep per channel
MAX_EPISODES_PER_CHANNEL=20

# How often to check for new videos (hours)
POLL_INTERVAL_HOURS=6

# Where to store audio files and the database (Railway volume mount)
DATA_DIR=/data

# Path to a Netscape-format cookies file exported from your browser (optional)
# Needed if YouTube returns "Sign in to confirm you're not a bot"
# Export with: yt-dlp --cookies-from-browser chrome --cookies /path/to/cookies.txt <any-url>
COOKIES_FILE=/data/cookies.txt
